    <parent link="camera_right_ir_frame" />
    <child link="camera_right_ir_optical_frame" />
    <origin xyz="0 0 0 " rpy="-1.57 0 -1.57" />
  </joint>
  
  <xacro:if value="${sensors_enabled}">

		<!-- Build GPS -->
		<xacro:if value="${gps_enabled}">
			<!-- <xacro:gps_macro parent="body_bottom_link"> -->
            <xacro:gps_macro parent="base_link">
				<!-- <origin xyz="${-0.525 + 0.05*2} 0.0 ${1.40 - 0.25 + 0.025/2}" rpy="0.0 0.0 0.0" /> -->
                <origin xyz="-0.25 0.0 0.0125" rpy="0.0 0.0 0.0" />
			</xacro:gps_macro>
		</xacro:if>

    <xacro:if value="${imu_enabled}">
			<xacro:imu_macro parent="base_link">
				<origin xyz="${-0.525 + 0.05/2} 0.0 0.3" rpy="0.0 0.0 0.0" />
			</xacro:imu_macro>
		</xacro:if>

		<!-- Build Velodyne -->
		<xacro:if value="${lidar_enabled}">
			<!-- <xacro:velodyne_macro parent="body_bottom_link"> -->
            <xacro:velodyne_macro parent="holder_link">
				<!-- <origin xyz="0.075 0.0 ${1.70 - 0.25}" rpy="0.0 0.0 0.0" /> -->
                <origin xyz="0.0 0.0 0.3" rpy="0.0 0.0 0.0" />
                <!-- <origin xyz="0.0 0.0 0.5" rpy="0.0 0.0 0.0" /> -->
			</xacro:velodyne_macro>
		</xacro:if>
	</xacro:if>
  
  <ros2_control name="bunker_hardware" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      <plugin>husky_base/HuskyHardware</plugin>
      <plugin>fake_components/GenericSystem</plugin>
      <param name="hw_start_duration_sec">2.0</param>
      <param name="hw_stop_duration_sec">3.0</param>
      <param name="wheel_diameter">0.3302</param>
      <param name="max_accel">5.0</param>
      <param name="max_speed">1.0</param>
      <param name="polling_timeout">10.0</param>
      <param name="serial_port">/dev/prolific</param>
    </hardware>

    <joint name="front_wheel_L_joint">
      <command_interface name="velocity">
        <param name="min">-1</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="back_wheel_L_joint">
      <command_interface name="velocity">
        <param name="min">-1</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_wheel_R_joint">
      <command_interface name="velocity">
        <param name="min">-1</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="back_wheel_R_joint">
      <command_interface name="velocity">
        <param name="min">-1</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo reference="base_link">
     <material>Gazebo/Gray</material>
  </gazebo>

  
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <!-- <robotNamespace>/</robotNamespace> -->
      <!-- <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType> -->
      <!-- <legacyModeNS>true</legacyModeNS> -->
      <parameters>$(arg gazebo_controllers)</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="base_link">
    <sensor name="my_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <plugin name="my_imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <!-- publish to /imu/data -->
          <namespace>imu</namespace>
          <remapping>~/out:=data</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="gps">
    <sensor name="gps_sensor" type="gps">
      <plugin filename="libgazebo_ros_gps_sensor.so" name="gps_plugin">
        <ros>
          <namespace>gps</namespace>
          <remapping>~/out:=data</remapping>
        </ros>
      </plugin>
      <always_on>true</always_on>
      <update_rate>10</update_rate>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="depth_camera" type="depth">
      <visualize>true</visualize>
      <update_rate>30.0</update_rate>
      <camera name="camera">
        <horizontal_fov>1.047198</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10</far>
        </clip>
      </camera>
      <plugin name="depth_camera_controller" filename="libgazebo_ros_camera.so">
        <baseline>0.2</baseline>
        <alwaysOn>true</alwaysOn>
        <updateRate>0.0</updateRate>
        <frame_name>camera_depth_optical_frame</frame_name>
        <pointCloudCutoff>0.5</pointCloudCutoff>
        <pointCloudCutoffMax>10.0</pointCloudCutoffMax>
        <distortionK1>0</distortionK1>
        <distortionK2>0</distortionK2>
        <distortionK3>0</distortionK3>
        <distortionT1>0</distortionT1>
        <distortionT2>0</distortionT2>
        <CxPrime>0</CxPrime>
        <Cx>0</Cx>
        <Cy>0</Cy>
        <focalLength>0</focalLength>
        <hackBaseline>0</hackBaseline>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_color_optical_joint">
    <sensor type="camera" name="rgb_cam">
      <update_rate>10.0</update_rate>
      <camera name="rgb_cam_SP">

          <pose>0 0 0 0 0 0</pose>

          <horizontal_fov>1.047198</horizontal_fov>
          <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
          </image>
          <clip>
              <near>0.01</near>
              <far>10.0</far>
          </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
          <alwaysOn>true</alwaysOn>
          <updateRate>0.0</updateRate>
          <cameraName>rgb_cam</cameraName>
          <imageTopicName>image_raw</imageTopicName>
          <cameraInfoTopicName>camera_info</cameraInfoTopicName>
          <frameName>camera_color_optical_joint</frameName>
          <hackBaseline>0.07</hackBaseline>
          <distortionK1>0.0</distortionK1>
          <distortionK2>0.0</distortionK2>
          <distortionK3>0.0</distortionK3>
          <distortionT1>0.0</distortionT1>
          <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>
<!-- 
